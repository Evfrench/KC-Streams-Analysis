Odd_Even_Years_Avg <- GreenRiver_WQ_Data %>%
subset(Year >= 2006) %>%
mutate(Month = lubridate::month(Month, label = T),
Even_Odd_Year = if_else(Year %% 2 == 0, 'Even_Year', 'Odd_Year')) %>%
group_by(Month, Locator, Parameter, Even_Odd_Year) %>%
summarise(Value = mean(Value, na.rm = T),
Units = first(Units))
