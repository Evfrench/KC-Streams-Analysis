library(dataRetrieval)
GreenRiver_Discharge <- Testflow %>% pivot_wider(id_cols = 'Date', names_from = 'SITE_CODE', values_from = 'AveQ') %>%
subset((Date <= as_date('1984/12/31') & Date >= as_date('1970/01/01')) | (Date >= as_date('2011/01/01'))) %>%
mutate(offset1 = `12113350`-`12113000`,
offset2 = `12113344`-`12113000`,
proportion = `12113344`/`12113000`)
Seasonal_discharge <- GreenRiver_Discharge %>%
mutate(Month = lubridate::month(Date))
Seasonal_discharge <- GreenRiver_Discharge %>%
mutate(Month = lubridate::month(Date)) %>%
group_by(Month)%>%
summarise(Avg_Diff_EarlyYears = mean(offset1, na.rm = T),
Median_Diff_EarlyYears = median(offset1, na.rm = T),
StDev_Diff_EarlyYears = sd(offset1, na.rm = T),
Avg_Diff_RecentYears = mean(offset2, na.rm = T),
Median_Diff_RecentYears = median(offset2, na.rm = T),
StDev_Diff_RecentYears = sd(offset2, na.rm = T),
Avg_Multiple_RecentYears = mean(proportion, na.rm = T),
Median_Multiple_RecentYears = median(proportion, na.rm = T),
StDev_Multiple_RecentYears = sd(proportion, na.rm = T)) %>%
round(digits = 0) %>%
ggplot(data = Testflow %>% subset((Date <= 1984 & Date >= 1960) | (Date >= 2011)), aes(Date, AveQ)) +
geom_line(aes(colour = factor(SITE_CODE)))
